    {
      "parameters": {
        "jsCode": "const rows = items;\nconst currentMessage = ($json.user_message || \"\").toLowerCase().trim();\n\nif (!rows || rows.length === 0) {\n  return [{ json: { history: \"\", last_user_message: \"\" } }];\n}\n\n// 👉 Sort by timestamp (VERY IMPORTANT)\nconst sorted = rows.sort((a, b) => {\n  return new Date(a.json.timestamp) - new Date(b.json.timestamp);\n});\n\nlet filtered = [];\n\nfor (const item of sorted) {\n  const msg = (item.json.user_message || \"\").toLowerCase().trim();\n\n  // ❌ Skip current message\n  if (msg === currentMessage) continue;\n\n  // ❌ Skip meta questions\n  if (\n    msg.includes(\"what was my last message\") ||\n    msg.includes(\"previous message\") ||\n    msg.includes(\"what did i say\")\n  ) continue;\n\n  // ❌ Skip greetings\n  if (msg === \"hi\" || msg === \"hello\") continue;\n\n  filtered.push(msg);\n}\n\n// Keep last 10\nconst lastMessages = filtered.slice(-10);\n\n// 👉 Get LAST meaningful message (CRITICAL)\nconst lastMessage = lastMessages.length > 0\n  ? lastMessages[lastMessages.length - 1]\n  : \"\";\n\n// Format history\nconst historyText = lastMessages.map(m => `User: ${m}`).join(\"\\n\");\n\nreturn [\n  {\n    json: {\n      history: historyText,\n      last_user_message: lastMessage\n    }\n  }\n];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
