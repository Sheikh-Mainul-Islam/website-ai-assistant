      "parameters": {
        "jsCode": "// 1️⃣ Pull rows from Google Sheets and filter out empty ones\nconst rows = items.filter(i => Object.keys(i.json).length > 0);\n\n// 2️⃣ Count the real messages\nconst messageCount = rows.length;\n\n// 3️⃣ Pull the original user message from 'Normalize Input'\nconst original = $node[\"Normalize Input\"].json;\n\n// 4️⃣ Normalize the user message for greeting detection\nconst msg = (original.user_message || \"\")\n    .toLowerCase()\n    .trim()\n    .replace(/[^\\w\\s]/g, \"\")   // remove punctuation (! ? . , etc.)\n    .replace(/\\s+/g, \" \");     // normalize spaces\n\n// 5️⃣ Define greetings\nconst greetings = [\n    \"hi\",\n    \"hello\",\n    \"hey\",\n    \"good morning\",\n    \"good noon\",\n    \"good afternoon\",\n    \"good evening\"\n];\n\n// 6️⃣ Detect if the message is a greeting (e.g., \"hi!\", \"hello bro!\")\nconst greetingDetected = greetings.some(greeting => msg === greeting || msg.startsWith(greeting + \" \"));\n\n// 7️⃣ Return all data\nreturn [\n    {\n        json: {\n            ...original,               // keep original user message and other fields\n            message_count: messageCount,\n            chat_history: rows,        // all previous messages\n            greeting_detected: greetingDetected // true/false\n        }\n    }\n];"
      },
