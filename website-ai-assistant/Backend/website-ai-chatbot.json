    {
      "parameters": {
        "jsCode": "// Pull the original user message directly from the 'Normalize Input' node\nconst userMessage = ($('Normalize Input').first().json.user_message || \"\").toLowerCase();\n\nlet reply;\n\nif (userMessage.includes(\"hi\")) {\n    reply = \"Hi! 😊 I’m Sheikh Mainul Islam. How can I help you today?\";\n} else if (userMessage.includes(\"hello\")) {\n    reply = \"Hello! 😊 I’m Sheikh Mainul Islam. How can I help you today?\";\n} else if (userMessage.includes(\"hey\")) {\n    reply = \"Hey! 👋 I’m Sheikh Mainul Islam. How’s your day going?\";\n} else if (\n    userMessage.includes(\"good morning\") ||\n    userMessage.includes(\"good afternoon\") ||\n    userMessage.includes(\"good evening\") ||\n    userMessage.includes(\"good noon\")\n) {\n    const timeOfDayMatch = userMessage.match(/morning|afternoon|evening|noon/);\n    const timeOfDay = timeOfDayMatch ? timeOfDayMatch[0] : \"\";\n    reply = `Good ${timeOfDay}! 😊 I’m Sheikh Mainul Islam. How can I assist you today?`;\n} else {\n    reply = \"Hello! 👋 I’m Sheikh Mainul Islam. How can I help you today?\";\n}\n\n// Return the reply and keep the rest of the JSON intact\nreturn [\n    {\n        json: {\n            ...$json,\n            reply // ✅ IMPORTANT: pass forward\n        },\n    },\n];"
      },
